# Supabase — Project Settings → API
# Project URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER use NEXT_PUBLIC_ prefix — server-only, never expose to browser
# Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — Email delivery (co-planner invite, RSVP notifications)
# https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key-here

# Site URL — used for building absolute links in emails
NEXT_PUBLIC_SITE_URL=http://localhost:3000
